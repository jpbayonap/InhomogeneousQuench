          RowBox[{
           RowBox[{"Norm", "[", "rhswp", "]"}], ",", 
           RowBox[{"10", "^", 
            RowBox[{"-", "50"}]}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<relative residual = \>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{"res", ",", "20"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
