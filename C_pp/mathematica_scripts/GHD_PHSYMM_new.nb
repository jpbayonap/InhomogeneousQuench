      RowBox[{"mode_", ":", "\"\<phsymm\>\""}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rVals", "=", 
