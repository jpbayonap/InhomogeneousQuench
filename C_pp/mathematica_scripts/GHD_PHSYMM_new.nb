             RowBox[{"gamma", " ", "2.0", " ", "Pi", " ", "J"}], ",", "0.0"}],
             "]"}], "-", 
           RowBox[{"fMat", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "r"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "1", ",", "M"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", "M"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rhs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"r", "==", "srcIdx"}], ",", 
            RowBox[{
             RowBox[{"-", "gamma"}], " ", "J"}], ",", "0.0"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "1", ",", "M"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Dimensions[A] = \>\"", ",", 
         RowBox[{"Dimensions", "[", "A", "]"}], 
         ",", "\"\<, Length[rhs] = \>\"", ",", 
         RowBox[{"Length", "[", "rhs", "]"}], ",", "\"\<, wp = \>\"", ",", 
         "wp"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Awp", "=", 
        RowBox[{"SetPrecision", "[", 
         RowBox[{"A", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rhswp", "=", 
        RowBox[{"SetPrecision", "[", 
         RowBox[{"rhs", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
