            RowBox[{"jAt", "[", 
             RowBox[{
             "#", ",", "rval", ",", "signval", ",", "rVals", ",", "bVals"}], 
             "]"}], "&"}], "/@", "zetasVal"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"badQ", "=", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Position", "[", 
            RowBox[{"qVals", ",", 
             RowBox[{"_", "?", 
              RowBox[{"(", 
               RowBox[{"Not", "@*", "finiteRealQ"}], ")"}]}], ",", 
             RowBox[{"{", "1", "}"}], ",", 
             RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"badJ", "=", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Position", "[", 
            RowBox[{"JVals", ",", 
             RowBox[{"_", "?", 
              RowBox[{"(", 
               RowBox[{"Not", "@*", "finiteRealQ"}], ")"}]}], ",", 
             RowBox[{"{", "1", "}"}], ",", 
             RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"badQ", "=!=", 
             RowBox[{"{", "}"}]}], "||", 
            RowBox[{"badJ", "=!=", 
             RowBox[{"{", "}"}]}]}], ",", 
           RowBox[{
            RowBox[{"Print", "[", 
             
             RowBox[{"\"\<ERROR: non-numeric values found. badQ=\>\"", ",", 
              "badQ", ",", "\"\< badJ=\>\"", ",", "badJ"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Continue", "[", "]"}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dataVals", "=", 
          RowBox[{"N", "@", 
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{"zetasVal", ",", "qVals", ",", "JVals"}], "}"}], 
            "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"plot", "=", 
          RowBox[{"ListLinePlot", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{"zetasVal", ",", "qVals"}], "}"}], "]"}], ",", 
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{"zetasVal", ",", "JVals"}], "}"}], "]"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"PlotLegends", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<q\>\"", ",", "\"\<J\>\""}], "}"}]}], ",", 
            RowBox[{"Frame", "->", "True"}], ",", 
            RowBox[{"FrameLabel", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<zeta\>\"", ",", "\"\<value\>\""}], "}"}]}], ",", 
            RowBox[{"PlotLabel", "->", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"ToUpperCase", "[", "state", "]"}], 
                ",", "\"\<, m=\>\"", ",", "p", ",", "\"\<, A=\>\"", ",", 
                "Aamp", ",", "\"\<, r=\>\"", ",", "rval", 
                ",", "\"\<, sign=\>\"", ",", "signval", ",", "\"\<, M=\>\"", ",",
                 "M", ",", "\"\<, gamma=\>\"", ",", "gamma", 
                ",", "\"\<, wp=\>\"", ",", "wp"}], "}"}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"ImageSize", "->", "700"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"gammaTag", "=", 
          RowBox[{"StringReplace", "[", 
           RowBox[{
            RowBox[{"ToString", "@", 
             RowBox[{"NumberForm", "[", 
              RowBox[{
               RowBox[{"N", "[", "gamma", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"Infinity", ",", "2"}], "}"}], ",", 
               RowBox[{"NumberPadding", "->", 
                RowBox[{"{", 
                 RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}]}], "]"}]}], ",", 
            RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"aTag", "=", 
          RowBox[{"StringReplace", "[", 
           RowBox[{
            RowBox[{"ToString", "@", 
             RowBox[{"NumberForm", "[", 
              RowBox[{
               RowBox[{"N", "[", "Aamp", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"Infinity", ",", "6"}], "}"}]}], "]"}]}], ",", 
            RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"stateTag", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"state", "===", "\"\<phsymm_odd\>\""}], 
            ",", "\"\<PHSYMM_ODD\>\"", ",", "\"\<PHSYMM\>\""}], "]"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"fileST", "=", 
          RowBox[{
           RowBox[{
           "StringTemplate", 
            "[", "\"\<GHD_``_m``_A``_r``_sign``_M``_gamma``_wp``_seggrid\>\"",
             "]"}], "[", 
           RowBox[{
           "stateTag", ",", "p", ",", "aTag", ",", "rval", ",", "signval", ",",
             "M", ",", "gammaTag", ",", "wp"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"csvOut", "=", 
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"csvDir", ",", 
             RowBox[{"fileST", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"pngOut", "=", 
          RowBox[{"FileNameJoin", "[", 
           RowBox[{"{", 
            RowBox[{"pngDir", ",", 
             RowBox[{"fileST", "<>", "\"\<.png\>\""}]}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Export", "[", 
          RowBox[{"csvOut", ",", 
           RowBox[{"Prepend", "[", 
            RowBox[{"dataVals", ",", 
             RowBox[{"{", 
              RowBox[{"\"\<zeta\>\"", ",", "\"\<q\>\"", ",", "\"\<J\>\""}], 
              "}"}]}], "]"}], ",", "\"\<CSV\>\""}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Export", "[", 
          RowBox[{"pngOut", ",", "plot", ",", "\"\<PNG\>\""}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Saved CSV: \>\"", ",", "csvOut"}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Saved PNG: \>\"", ",", "pngOut"}], "]"}], ";"}]}], 
