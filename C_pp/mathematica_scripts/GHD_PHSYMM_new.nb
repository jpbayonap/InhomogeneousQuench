               RowBox[{"r", "^", "2"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{"4", " ", 
                RowBox[{"r", "^", "2"}]}]}], ")"}]}], ",", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"EvenQ", "[", 
               RowBox[{"n", "+", "r"}], "]"}], ",", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"32.0", " ", 
                 RowBox[{"J", "^", "2"}], " ", "n", " ", "r"}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"n", "^", "4"}], "-", 
                 RowBox[{"2", " ", 
                  RowBox[{"n", "^", "2"}], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"r", "^", "2"}], "+", "1"}], ")"}]}], "+", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"r", "^", "2"}], "-", "1"}], ")"}], "^", "2"}]}], 
                ")"}]}], ",", "0.0"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", "M"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "1", ",", "M"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"BC", " ", 
          RowBox[{"convention", ":", "DeltaJ"}]}], "=", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "gamma", " ", "q0"}]}], "*)"}], 
       RowBox[{"A", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
