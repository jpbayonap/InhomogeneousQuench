          RowBox[{
           RowBox[{"2", " ", "p"}], "+", "1"}], ",", 
          RowBox[{"2", " ", "p"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"srcIdx", "<", "1"}], "||", 
          RowBox[{"srcIdx", ">", "M"}]}], ",", 
         RowBox[{"Print", "[", 
          
          RowBox[{"\"\<WARNING: source index \>\"", ",", "srcIdx", 
           ",", "\"\< outside truncation M=\>\"", ",", "M", 
           ",", "\"\<. rhs will be zero.\>\""}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fMat", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", 
