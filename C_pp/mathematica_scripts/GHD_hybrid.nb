Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "deltaTagLocal", ",", "solLocal", ",", "rValsLocal", ",", 
         "bValsLocal", ",", "chiVals", ",", "badChi", ",", 
         "\[IndentingNewLine]", "dataVals", ",", "plot", ",", "gammaTagLocal",
          ",", "stateTagLocal", ",", "fileST", ",", "csvOut", ",", "pngOut"}],
         "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"deltaTagLocal", "=", 
         RowBox[{"\"\<delta\>\"", "<>", 
          RowBox[{"ToString", "[", 
           RowBox[{"Length", "[", "delta", "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Running ChiPlus for state=\>\"", ",", "state", 
          ",", "\"\< \>\"", ",", "deltaTagLocal"}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"solLocal", "=", 
         RowBox[{"SolveTruncatedSystemDirectEff", "[", 
          RowBox[{
          "M", ",", "Jhop", ",", "gamma", ",", "delta", ",", "state", ",", 
           "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"solLocal", "===", "$Failed"}], ",", "\[IndentingNewLine]", 
          
          RowBox[{
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<ERROR: solver failed for \>\"", ",", 
             "deltaTagLocal"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Continue", "[", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rValsLocal", ",", "bValsLocal"}], "}"}], "=", "solLocal"}],
         ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"chiVals", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"ChiPlus", "[", 
              RowBox[{"#", ",", "rValsLocal", ",", "bValsLocal"}], "]"}], 
             "&"}], "/@", "kVals"}], ",", "16"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"badChi", "=", 
         RowBox[{"Flatten", "@", 
          RowBox[{"Position", "[", 
           RowBox[{"chiVals", ",", 
            RowBox[{"_", "?", 
             RowBox[{"(", 
              RowBox[{"Not", "@*", "finiteRealQ"}], ")"}]}], ",", 
            RowBox[{"{", "1", "}"}], ",", 
            RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"badChi", "=!=", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<ERROR: non-numeric ChiPlus values found. badChi=\>\"",
              ",", "badChi"}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Continue", "[", "]"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"dataVals", "=", 
         RowBox[{"N", "@", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"kVals", ",", "chiVals"}], "}"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"plot", "=", 
         RowBox[{"ListLinePlot", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"kVals", ",", "chiVals"}], "}"}], "]"}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"PlotLegends", "->", 
            RowBox[{"{", "\"\<ChiPlus\>\"", "}"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<k\>\"", ",", "\"\<\[Chi]Plus\>\""}], "}"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"PlotLabel", "->", 
            RowBox[{"Row", "[", 
             RowBox[{"{", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"ToUpperCase", "[", "state", "]"}], 
               ",", "\"\< ChiPlus, \>\"", ",", "deltaTagLocal", ",", 
               "\[IndentingNewLine]", "\"\<, M=\>\"", ",", "M", ",", 
               "\[IndentingNewLine]", "\"\<, gamma=\>\"", ",", "gamma", ",", 
               "\[IndentingNewLine]", "\"\<, wp=\>\"", ",", "wp"}], 
              "\[IndentingNewLine]", "}"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"ImageSize", "->", "700"}]}], "\[IndentingNewLine]", 
          "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"gammaTagLocal", "=", 
         RowBox[{"StringReplace", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"ToString", "@", 
            RowBox[{"NumberForm", "[", 
             RowBox[{
              RowBox[{"N", "[", "gamma", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"Infinity", ",", "2"}], "}"}], ",", 
              RowBox[{"NumberPadding", "->", 
               RowBox[{"{", 
                RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}]}], "]"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"stateTagLocal", "=", 
         RowBox[{"Switch", "[", "\[IndentingNewLine]", 
          RowBox[{
          "state", ",", "\[IndentingNewLine]", "\"\<neel\>\"", 
           ",", "\"\<NEEL\>\"", ",", 
           "\[IndentingNewLine]", "\"\<polarized\>\"", 
           ",", "\"\<POLARIZED\>\"", ",", "\[IndentingNewLine]", "_", 
           ",", "\"\<UNKNOWN\>\""}], "\[IndentingNewLine]", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"fileST", "=", 
         RowBox[{
          RowBox[{
          "StringTemplate", "[", 
           "\[IndentingNewLine]", "\"\<CHI_PLUS_``_``_M``_gamma``_wp``\>\"", 
           "\[IndentingNewLine]", "]"}], "[", 
          RowBox[{
          "stateTagLocal", ",", "deltaTagLocal", ",", "M", ",", 
           "gammaTagLocal", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"csvOut", "=", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"chiCsvDir", ",", 
            RowBox[{"fileST", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pngOut", "=", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{"chiPngDir", ",", 
            RowBox[{"fileST", "<>", "\"\<.png\>\""}]}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Export", "[", 
         RowBox[{"csvOut", ",", 
          RowBox[{"Prepend", "[", 
           RowBox[{"dataVals", ",", 
            RowBox[{"{", 
             RowBox[{"\"\<k\>\"", ",", "\"\<ChiPlus\>\""}], "}"}]}], "]"}], 
          ",", "\"\<CSV\>\""}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Export", "[", 
         RowBox[{"pngOut", ",", "plot", ",", "\"\<PNG\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Saved ChiPlus CSV: \>\"", ",", "csvOut"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Saved ChiPlus PNG: \>\"", ",", "pngOut"}], "]"}], 
        ";"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"delta", ",", "deltaRTable"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}], ";"}], "\n", "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"--", 
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"--", 
        RowBox[{"--", "Optional"}]}]}]}]}], " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"diagnostics", "--"}], "--"}], "--"}], "--"}], "--"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<=== BEGIN DIAGNOSTICS ===\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z0", "=", 
   RowBox[{"-", "0.0033333"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q0", "=", 
   RowBox[{"qAt", "[", 
    RowBox[{
    "z0", ",", "rDiag", ",", "Jhop", ",", "signDiag", ",", "rVals", ",", 
     "bVals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"j0", "=", 
   RowBox[{"jAt", "[", 
    RowBox[{
    "z0", ",", "rDiag", ",", " ", "Jhop", ",", " ", "signDiag", ",", "rVals", 
     ",", "bVals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
