                 "signval", ",", "M", ",", "gammaTagLocal", ",", "wp"}], 
                "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"csvOut", "=", 
               RowBox[{"FileNameJoin", "[", 
                RowBox[{"{", 
                 RowBox[{"csvDir", ",", 
                  RowBox[{"fileST", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}]}], 
              ";", "\[IndentingNewLine]", 
              RowBox[{"pngOut", "=", 
               RowBox[{"FileNameJoin", "[", 
                RowBox[{"{", 
                 RowBox[{"pngDir", ",", 
                  RowBox[{"fileST", "<>", "\"\<.png\>\""}]}], "}"}], "]"}]}], 
              ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"Export", "[", 
