        RowBox[{"export", "--"}], "--"}], "--"}], "--"}], "--"}]}], "*)"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "deltaTagLocal", ",", "solLocal", ",", "rValsLocal", ",", 
          "bValsLocal", ",", "gammaTagLocal", ",", "stateTagLocal"}], "}"}], ",",
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"deltaTagLocal", "=", 
          RowBox[{"\"\<delta\>\"", "<>", 
           RowBox[{"ToString", "[", 
            RowBox[{"Length", "[", "delta", "]"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          
          RowBox[{"\"\<=== Running profiles for \>\"", ",", "state", 
           ",", "\"\< \>\"", ",", "deltaTagLocal", ",", "\"\< ===\>\""}], 
          "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"solLocal", "=", 
          RowBox[{"SolveTruncatedSystemDirectEff", "[", 
           RowBox[{
           "M", ",", "Jhop", ",", "gamma", ",", "delta", ",", "state", ",", 
            "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"solLocal", "===", "$Failed"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"Print", "[", 
             
             RowBox[{"\"\<ERROR: solver failed for \>\"", ",", 
              "deltaTagLocal"}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Continue", "[", "]"}], ";"}]}], "\[IndentingNewLine]", 
          "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"rValsLocal", ",", "bValsLocal"}], "}"}], "=", 
          "solLocal"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"gammaTagLocal", "=", 
          RowBox[{"StringReplace", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ToString", "@", 
             RowBox[{"NumberForm", "[", 
              RowBox[{
               RowBox[{"N", "[", "gamma", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"Infinity", ",", "2"}], "}"}], ",", 
               RowBox[{"NumberPadding", "->", 
                RowBox[{"{", 
                 RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}]}], "]"}]}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"\"\< \>\"", "->", "\"\<\>\""}]}], "\[IndentingNewLine]", 
           "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"stateTagLocal", "=", 
          RowBox[{"Switch", "[", "\[IndentingNewLine]", 
           RowBox[{
           "state", ",", "\[IndentingNewLine]", "\"\<neel\>\"", 
            ",", "\"\<NEEL\>\"", ",", 
            "\[IndentingNewLine]", "\"\<polarized\>\"", 
            ",", "\"\<POLARIZED\>\"", ",", "\[IndentingNewLine]", "_", 
            ",", "\"\<UNKNOWN\>\""}], "\[IndentingNewLine]", "]"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Module", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
              "qVals", ",", "JVals", ",", "badQ", ",", "badJ", ",", 
