                 RowBox[{"PlotLegends", "->", 
                  RowBox[{"{", 
                   RowBox[{"\"\<q\>\"", ",", "\"\<J\>\""}], "}"}]}], ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"Frame", "->", "True"}], ",", "\[IndentingNewLine]", 
                 
                 RowBox[{"FrameLabel", "->", 
