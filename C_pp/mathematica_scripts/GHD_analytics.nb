Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
   "2.", " ", "GHD", " ", "profiles", " ", "vs", " ", "zeta", " ", "and", " ",
     "export"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "ComputeGHDProfiles", "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ComputeGHDProfiles", "[", 
     RowBox[{
      RowBox[{"M_Integer", "?", "Positive"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"truncation", " ", "in", " ", "r"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"J_", "?", "NumericQ"}], ",", 
      RowBox[{"gamma_", "?", "NumericQ"}], ",", "r_Integer", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"charge", " ", "index", " ", "r"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"sign_", ":", "\"\<-\>\""}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"\"\<+\>\"", " ", "or", " ", "\"\<-\>\""}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"zetaMin_", ":", 
       RowBox[{"-", "1.0"}]}], ",", 
      RowBox[{"zetaMax_", ":", "1.0"}], ",", 
      RowBox[{"numZeta_", ":", "201"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "\"\< modify this part!\>\"", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
      "outDir_", ":", "\"\</Users/juan/Desktop/Bologna/INH_QUENCH/\>\""}], ",", 
      RowBox[{"tag_", ":", "\"\<\>\""}]}], "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rVals", ",", "bVals", ",", "zetas", ",", "qVals", ",", "JVals", ",", 
        "data", ",", "labelSign", ",", "plot", ",", "fileBase"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
       "Print", "[", "\"\<Solving truncated system for b_r...\>\"", "]"}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Solve", " ", "truncated", " ", "series", " ", "for", " ", "b_n"}], ",",
          " ", 
         RowBox[{
          RowBox[{
           RowBox[{"\\", "phi_R"}], 
           RowBox[{"(", "k", ")"}]}], "=", " ", 
          RowBox[{
           RowBox[{"\\", "sum_"}], 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"n", "=", "1"}], "}"}], "^"}], "\\", "infty"}], " ", 
           RowBox[{"b_n", " ", "\\", "sin"}], 
           RowBox[{"(", "nk", ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Iterative", " ", "Solution"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"rVals", ",", "bVals"}], "}"}], "=", 
          RowBox[{"SolveTruncatedSystemIterative", "[", 
           RowBox[{"M", ",", "J", ",", "gamma", ",", "  ", "400"}], "]"}]}], 
         ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Linear", " ", "System", " ", "Solution"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rVals", ",", "bVals"}], "}"}], "=", 
        RowBox[{"SolveTruncatedSystemDirect", "[", 
         RowBox[{"M", ",", "J", ",", "gamma"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Building zeta grid...\>\"", "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"zetas", "=", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"zetaMin", ",", "zetaMax", ",", 
          RowBox[{"numZeta", "-", "1"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
       "Print", "[", "\"\<Computing hydrodynamic charges...\>\"", "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"qVals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"HydCharge", "[", 
           RowBox[{
           "r", ",", "\[Zeta]", ",", "sign", ",", "rVals", ",", "bVals"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Zeta]", ",", "zetas"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
       "Print", "[", "\"\<Computing hydrodynamic currents...\>\"", "]"}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"JVals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"HydCurrent", "[", 
           RowBox[{
           "r", ",", "\[Zeta]", ",", "sign", ",", "rVals", ",", "bVals"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Zeta]", ",", "zetas"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Pack", " ", "data", " ", "as", " ", 
         RowBox[{"{", 
          RowBox[{"zeta", ",", 
           RowBox[{"q", 
            RowBox[{"(", "zeta", ")"}]}], ",", 
           RowBox[{"J", 
            RowBox[{"(", "zeta", ")"}]}]}], "}"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"zetas", ",", "qVals", ",", "JVals"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
