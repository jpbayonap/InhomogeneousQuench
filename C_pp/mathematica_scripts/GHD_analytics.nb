Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"1.", " ", "Local", " ", "HydCharge"}], ",", "HydCurrent"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"HydCharge", ",", "HydCurrent"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"HydCharge", "[", 
      RowBox[{"r_Integer", ",", 
       RowBox[{"zeta_", "?", "NumericQ"}], ",", 
       RowBox[{"sign_", ":", "\"\<-\>\""}], ",", "rVals_List", ",", 
       "bVals_List"}], "]"}], ":=", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "f", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"k_", "?", "NumericQ"}], "]"}], ":=", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"sign", "===", "\"\<-\>\""}], ",", 
            RowBox[{"qMinus", "[", 
             RowBox[{"k", ",", "r"}], "]"}], ",", 
            RowBox[{"qPlus", "[", 
             RowBox[{"k", ",", "r"}], "]"}]}], "]"}], "*", 
          "\[IndentingNewLine]", 
          RowBox[{"nZeta", "[", 
           RowBox[{"k", ",", "zeta", ",", "rVals", ",", "bVals"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"NIntegrate", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"f", "[", "k", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Method", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<GlobalAdaptive\>\"", ",", 
             RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"MinRecursion", "->", "4"}], ",", "\[IndentingNewLine]", 
          RowBox[{"MaxRecursion", "->", "40"}], ",", "\[IndentingNewLine]", 
          RowBox[{"AccuracyGoal", "->", "8"}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"HydCurrent", "[", 
      RowBox[{"r_Integer", ",", 
       RowBox[{"zeta_", "?", "NumericQ"}], ",", 
       RowBox[{"sign_", ":", "\"\<-\>\""}], ",", "rVals_List", ",", 
       "bVals_List"}], "]"}], ":=", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "f", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", 
          RowBox[{"k_", "?", "NumericQ"}], "]"}], ":=", "\[IndentingNewLine]", 
         RowBox[{"2.0", "*", 
          RowBox[{"Sin", "[", "k", "]"}], "*", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"sign", "===", "\"\<-\>\""}], ",", 
            RowBox[{"qMinus", "[", 
             RowBox[{"k", ",", "r"}], "]"}], ",", 
            RowBox[{"qPlus", "[", 
             RowBox[{"k", ",", "r"}], "]"}]}], "]"}], "*", 
          "\[IndentingNewLine]", 
          RowBox[{"nZeta", "[", 
           RowBox[{"k", ",", "zeta", ",", "rVals", ",", "bVals"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{"f", "[", "k", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
