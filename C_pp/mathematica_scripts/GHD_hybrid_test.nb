    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"once", "--"}], "--"}], "--"}], "--"}], "--"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"SolveTruncatedSystemDirectEff", "[", 
      RowBox[{"M", ",", "Jhop", ",", "gamma", ",", 
       RowBox[{"{", "}"}], ",", " ", "state", ",", " ", "wp"}], "]"}]}], 
    ";"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"SolveTruncatedSystemDirectEff", "[", 
      RowBox[{
      "M", ",", "Jhop", ",", "gamma", ",", "deltaR", ",", " ", "state", ",", 
       " ", "wp"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rVals", ",", "bVals"}], "}"}], "=", "sol"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<=== BEGIN DIAGNOSTICS ===\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z0", "=", 
     RowBox[{"-", "0.01"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rDiag", "=", "3"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"q0", "=", 
     RowBox[{"qAt", "[", 
      RowBox[{
      "z0", ",", "rDiag", ",", "Jhop", ",", "signDiag", ",", "rVals", ",", 
       "bVals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"j0", "=", 
     RowBox[{"jAt", "[", 
      RowBox[{
      "z0", ",", "rDiag", ",", " ", "Jhop", ",", " ", "signDiag", ",", 
       "rVals", ",", "bVals"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rDiag", "*", "q0"}], ",", 
     RowBox[{"finiteRealQ", "[", "q0", "]"}]}], "}"}], "\[IndentingNewLine]", 
   
   RowBox[{"{", 
    RowBox[{"q0", ",", 
     RowBox[{"finiteRealQ", "[", "q0", "]"}]}], "}"}], "\[IndentingNewLine]", 
   
   RowBox[{"{", 
    RowBox[{"j0", ",", 
     RowBox[{"finiteRealQ", "[", "j0", "]"}]}], "}"}], "\[IndentingNewLine]", 
   
