              "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               
               RowBox[{"\"\<Running \>\"", ",", "deltaTagLocal", 
                ",", "\"\< r=\>\"", ",", "rval", ",", "\"\< sign=\>\"", ",", 
                "signval"}], "]"}], ";", "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"qVals", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"qAt", "[", 
                  RowBox[{
                  "#", ",", "rval", ",", "Jhop", ",", "signval", ",", 
                   "rValsLocal", ",", "bValsLocal"}], "]"}], "&"}], "/@", 
                "zetasVal"}]}], ";", "\[IndentingNewLine]", 
              RowBox[{"JVals", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"jAt", "[", 
                  RowBox[{
                  "#", ",", "rval", ",", "Jhop", ",", "signval", ",", 
                   "rValsLocal", ",", "bValsLocal"}], "]"}], "&"}], "/@", 
                "zetasVal"}]}], ";", "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"badQ", "=", 
               RowBox[{"Flatten", "@", 
                RowBox[{"Position", "[", 
                 RowBox[{"qVals", ",", 
                  RowBox[{"_", "?", 
                   RowBox[{"(", 
                    RowBox[{"Not", "@*", "finiteRealQ"}], ")"}]}], ",", 
                  RowBox[{"{", "1", "}"}], ",", 
                  RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"badJ", "=", 
               RowBox[{"Flatten", "@", 
                RowBox[{"Position", "[", 
                 RowBox[{"JVals", ",", 
                  RowBox[{"_", "?", 
                   RowBox[{"(", 
                    RowBox[{"Not", "@*", "finiteRealQ"}], ")"}]}], ",", 
                  RowBox[{"{", "1", "}"}], ",", 
                  RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"badQ", "=!=", 
                  RowBox[{"{", "}"}]}], "||", 
                 RowBox[{"badJ", "=!=", 
                  RowBox[{"{", "}"}]}]}], ",", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"Print", "[", 
                  
                  RowBox[{"\"\<ERROR: non-numeric values found. badQ=\>\"", ",",
