Cell[BoxData[""], "Input",ExpressionUUID->"e151962b-31d0-4170-b0be-0bc234f3d436"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "run"}]}], " ", "with", " ", "new", " ", "high"}], "-", 
    RowBox[{"precision", " ", 
     RowBox[{"solver", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"M", "=", "800"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"J", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"P", "=", "1"}], ";"}], "          ", 
   RowBox[{"(*", "m", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Aamp", "=", "0.5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gamma", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wp", "=", "80"}], ";"}], "        ", 
   RowBox[{"(*", 
    RowBox[{"solver", " ", "precision"}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"SolveTruncatedSystemDirectEff", "[", 
      RowBox[{"M", ",", "P", ",", "J", ",", "gamma", ",", "wp"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rVals", ",", "bVals"}], "}"}], "=", "sol"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"choose", " ", "profile"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"rTest", "=", "2"}], ";", "\n", 
     RowBox[{"signTest", "=", "\"\<-\>\""}], ";"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zetasVal", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Subdivide", "[", 
        RowBox[{
         RowBox[{"-", "2.5"}], ",", 
         RowBox[{"-", "1."}], ",", "40"}], "]"}], ",", 
       RowBox[{"Rest", "@", 
        RowBox[{"Subdivide", "[", 
         RowBox[{
          RowBox[{"-", "1."}], ",", "1.", ",", "140"}], "]"}]}], ",", 
       RowBox[{"Rest", "@", 
        RowBox[{"Subdivide", "[", 
         RowBox[{"1.", ",", "2.5", ",", "40"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"profileList", "=", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", ",", "\"\<-\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", " ", "6"}], "}"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"r", ",", "\"\<+\>\""}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", 
           RowBox[{"{", 
            RowBox[{"3", ",", " ", "5"}], "}"}]}], "}"}]}], " ", "]"}]}], " ",
       "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"outBase", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        ",", "\"\<GHD_PHSYMM_mat\>\""}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"csvDir", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"outBase", ",", "\"\<csv\>\""}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"pngDir", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{"outBase", ",", "\"\<png\>\""}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"zetas", "=", " ", 
      RowBox[{"{", 
       RowBox[{"-", "1.5"}], "}"}]}], ";"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"chargeIntegrand", ",", "currentIntegrand"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"chargeIntegrand", "[", 
      RowBox[{
       RowBox[{"k_", "?", "NumericQ"}], ",", 
       RowBox[{"p_Integer", "?", "Positive"}], ",", 
       RowBox[{"r_Integer", "?", "NonNegative"}], ",", 
       RowBox[{"zeta_", "?", "NumericQ"}], ",", "sign_String", ",", 
       "rVals_List", ",", "bVals_List"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"sign", "===", "\"\<-\>\""}], ",", 
        RowBox[{"qMinus", "[", 
         RowBox[{"k", ",", "r"}], "]"}], ",", 
        RowBox[{"qPlus", "[", 
         RowBox[{"k", ",", "r"}], "]"}]}], "]"}], "*", 
      RowBox[{"nZeta", "[", 
       RowBox[{"k", ",", "p", ",", "zeta", ",", "rVals", ",", "bVals"}], 
       "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"currentIntegrand", "[", 
      RowBox[{
       RowBox[{"k_", "?", "NumericQ"}], ",", 
       RowBox[{"p_Integer", "?", "Positive"}], ",", 
       RowBox[{"r_Integer", "?", "NonNegative"}], ",", 
       RowBox[{"zeta_", "?", "NumericQ"}], ",", "sign_String", ",", 
       "rVals_List", ",", "bVals_List"}], "]"}], ":=", 
     RowBox[{"2.", " ", 
      RowBox[{"Sin", "[", "k", "]"}], "*", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"sign", "===", "\"\<-\>\""}], ",", 
        RowBox[{"qMinus", "[", 
         RowBox[{"k", ",", "r"}], "]"}], ",", 
        RowBox[{"qPlus", "[", 
         RowBox[{"k", ",", "r"}], "]"}]}], "]"}], "*", 
      RowBox[{"nZeta", "[", 
       RowBox[{"k", ",", "p", ",", "zeta", ",", "rVals", ",", "bVals"}], 
       "]"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rval", ",", "signval"}], "}"}], "=", "rs"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Running r=\>\"", ",", "rval", ",", "\"\< sign=\>\"", ",",
          "signval"}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"qVals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{"Evaluate", "@", 
             RowBox[{"chargeIntegrand", "[", 
              RowBox[{
              "k", ",", "P", ",", "rval", ",", "z", ",", "signval", ",", 
               "rVals", ",", "bVals"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
            RowBox[{"Method", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<GlobalAdaptive\>\"", ",", 
               RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}], ",", 
            RowBox[{"MinRecursion", "->", "3"}], ",", 
            RowBox[{"MaxRecursion", "->", "40"}], ",", 
            RowBox[{"AccuracyGoal", "->", "10"}], ",", 
            RowBox[{"PrecisionGoal", "->", "10"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"z", ",", "zetasVal"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\n", "    ", 
       RowBox[{"JVals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{"Evaluate", "@", 
             RowBox[{"currentIntegrand", "[", 
              RowBox[{
              "k", ",", "P", ",", "rval", ",", "z", ",", "signval", ",", 
               "rVals", ",", "bVals"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
            RowBox[{"Method", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<GlobalAdaptive\>\"", ",", 
               RowBox[{"\"\<SymbolicProcessing\>\"", "->", "0"}]}], "}"}]}], ",", 
            RowBox[{"MinRecursion", "->", "3"}], ",", 
            RowBox[{"MaxRecursion", "->", "40"}], ",", 
            RowBox[{"AccuracyGoal", "->", "12"}], ",", 
            RowBox[{"PrecisionGoal", "->", "10"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"z", ",", "zetasVal"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Done with integration\>\"", "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"dataVals", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"zetasVal", ",", "qVals", ",", "JVals"}], "}"}], "]"}]}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"plot", "=", 
        RowBox[{"ListLinePlot", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"zetasVal", ",", "qVals"}], "}"}], "]"}], ",", 
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"zetasVal", ",", "JVals"}], "}"}], "]"}]}], "}"}], ",", 
          
          RowBox[{"PlotLegends", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<q\>\"", ",", "\"\<J\>\""}], "}"}]}], ",", 
          RowBox[{"Frame", "->", "True"}], ",", 
          RowBox[{"FrameLabel", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<zeta\>\"", ",", "\"\<value\>\""}], "}"}]}], ",", 
          RowBox[{"PlotLabel", "->", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             
             RowBox[{"\"\<PHSYMM, m=\>\"", ",", "P", ",", "\"\<, A=\>\"", ",",
               "Aamp", ",", "\"\<, r=\>\"", ",", "rval", 
              ",", "\"\<, sign=\>\"", ",", "signval", ",", "\"\<, M=\>\"", ",",
               "M", ",", "\"\<, gamma=\>\"", ",", "gamma"}], "}"}], "]"}]}], ",", 
          RowBox[{"ImageSize", "->", "700"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"fileST", "=", 
        RowBox[{
         RowBox[{
         "StringTemplate", 
          "[", "\"\<GHD_PHSYMM_m``_A``_r``_sign``_M``_gamma``_seggrid\>\"", 
          "]"}], "[", 
         RowBox[{
         "P", ",", "Aamp", ",", "rval", ",", "signval", ",", "M", ",", 
          "gamma"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"csvOut", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"csvDir", ",", 
           RowBox[{"fileST", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pngOut", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"pngDir", ",", 
           RowBox[{"fileST", "<>", "\"\<.png\>\""}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"csvOut", ",", 
         RowBox[{"Prepend", "[", 
          RowBox[{"dataVals", ",", 
           RowBox[{"{", 
            RowBox[{"\"\<zeta\>\"", ",", "\"\<q\>\"", ",", "\"\<J\>\""}], 
            "}"}]}], "]"}], ",", "\"\<CSV\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"pngOut", ",", "plot", ",", "\"\<PNG\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Saved CSV: \>\"", ",", "csvOut"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Saved PNG: \>\"", ",", "pngOut"}], "]"}], ";"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"rs", ",", "profileList"}], "}"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", "\n", "\n", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\n"}]}]], "Input",
