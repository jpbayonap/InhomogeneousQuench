Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.974306442678547*^9, 3.974306456480927*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"a1ec6bf6-3d6c-4518-a485-e9b10b6208e3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cutOff", "=", "150"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"number", " ", "of", " ", "coefficients", " ", 
    RowBox[{"a", "[", "n", "]"}], " ", "kept", " ", "in", " ", "the", " ", 
    "sums"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Gamma]", "=", "4"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"value", " ", "of", " ", "the", " ", "interactions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "r", "]"}], "=", 
      RowBox[{"N", "[", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"2", "*", 
          SuperscriptBox["\[Pi]", "2"], "*", "r"}]], 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", "1"}], ")"}], "r"]}], ")"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "cutOff"}], "}"}]}], "]"}], ";"}], " ", 
  RowBox[{"(*", "initialization", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"aNew", "[", "r", "]"}], "=", 
      RowBox[{"a", "[", "r", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "cutOff"}], "}"}]}], "]"}], ";"}], " ", 
  RowBox[{"(*", "initialization", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"n", ",", "r"}], "]"}], "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", "==", "r"}], ",", 
        RowBox[{"N", "[", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{"32", "*", 
            SuperscriptBox["r", "2"]}], 
           RowBox[{"1", "-", 
            RowBox[{"4", "*", 
             SuperscriptBox["r", "2"]}]}]], ")"}], "]"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], 
            RowBox[{"n", "+", "r"}]], "==", 
           RowBox[{"-", "1"}]}], ",", "0", ",", 
          RowBox[{"N", "[", 
           FractionBox[
            RowBox[{"16", "*", "n", "*", "r", "*", 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"-", "1"}], ")"}], 
                RowBox[{"n", "+", "r"}]]}], ")"}]}], 
            RowBox[{
             SuperscriptBox["n", "4"], "-", 
             RowBox[{"2", "*", 
              SuperscriptBox["n", "2"], 
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["r", "2"], "+", "1"}], ")"}]}], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["r", "2"], "-", "1"}], ")"}], "2"]}]], "]"}]}],
          "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "cutOff"}], "}"}], ",", 
    RowBox[{"{", 
