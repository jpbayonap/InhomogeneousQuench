Cell[BoxData[{
 RowBox[{
  RowBox[{"numIterations", "=", "400"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"aNew", "[", "r", "]"}], "=", 
        RowBox[{
         RowBox[{
          FractionBox["1", 
           RowBox[{"2", "*", 
            SuperscriptBox["\[Pi]", "2"], "*", "r"}]], 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], "r"]}], ")"}]}], "+", 
         RowBox[{
          FractionBox["1", 
           RowBox[{"\[Gamma]", "*", "r", "*", "\[Pi]"}]], 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"a", "[", "n", "]"}], "*", 
             RowBox[{"f", "[", 
              RowBox[{"n", ",", "r"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "1", ",", "cutOff"}], "}"}]}], "]"}]}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "1", ",", "cutOff"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"a", "[", "r", "]"}], "=", 
         RowBox[{"aNew", "[", "r", "]"}]}], ";"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "1", ",", "cutOff"}], "}"}]}], "]"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"s", ",", "1", ",", "numIterations"}], "}"}]}], "]"}], 
  ";"}]}], "Input",
